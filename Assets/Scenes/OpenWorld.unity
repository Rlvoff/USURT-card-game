    - target: {fileID: 7812618588097602600, guid: 3d51511d02e734d4e9813da72b74e40d, type: 3}
      propertyPath: startNode.dialogueText
      value: "\u041E! \u041A\u0430\u0436\u0435\u0442\u0441\u044F \u043A \u043D\u0430\u043C
        \u043F\u0440\u0438\u0431\u044B\u043B\u0430 \u043D\u043E\u0432\u0430\u044F
        \u043F\u0430\u0440\u0442\u0438\u044F \u043F\u0435\u0440\u0432\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u043E\u0432?\n\u041C\u0435\u043D\u044F
        \u0437\u043E\u0432\u0443\u0442 \u0420\u043E\u043C\u0430, \u044F - \u043F\u0435\u0440\u0432\u044B\u0439
        \u0438\u0437 \u043F\u044F\u0442\u0438 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u0432.
        \u042F \u043E\u0431\u044A\u044F\u0441\u043D\u044E \u0442\u0435\u0431\u0435,
        \u0447\u0442\u043E \u0442\u0443\u0442 \u043A \u0447\u0435\u043C\u0443."
      objectReference: {fileID: 0}
